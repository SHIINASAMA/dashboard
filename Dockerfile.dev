FROM node:22-slim
RUN npm install -g pnpm
WORKDIR /app

# curl is needed by the Reddit public fetcher
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

# Install deps
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

EXPOSE 3000

CMD ["pnpm", "dev"]

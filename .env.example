# 用于原有脚本 (抓取其他用户数据)
AUTH_TOKEN=your_x_auth_token
GET_ID_X_TOKEN=your_x_guest_token

# ── Dashboard Secret (必须) ───────────────────────────────────────
# Generate: openssl rand -hex 32
DASHBOARD_SECRET=884c5126b11b2e06da6ec17f2839747685970feb6ee4ae6ec556af90bba63d2e

# ── PostgreSQL 连接 (生产环境使用，替代 SQLite)
# DATABASE_URL=postgresql://dashboard:yourpassword@localhost:5432/dashboard
# 或使用独立变量：
PG_USER=dashboard
PG_PASSWORD=dashboard
PG_DB=dashboard
PG_PORT=5432

# ── CORS (可选，逗号分隔的允许域名)
# ALLOWED_ORIGINS=https://my.dashboard.com
# ALLOWED_ORIGINS=*

# ── 预设 admin 密码 (可选，argon2id hash)
# ADMIN_PASSWORD_HASH=$argon2id$...

# ── 日志配置
LOG_DIR=data/logs           # 日志存放目录（默认 data/logs）
LOG_LEVEL=info              # 日志级别: trace/debug/info/warn/error/fatal
LOG_MAX_SIZE=10m            # 单个日志文件滚动大小（默认 10m）
LOG_MAX_FILES=5             # 保留的历史日志文件数（默认 5）

# 代理设置（用于访问 X.com / gitlab.com 等）
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890

# ── TLS 验证（可选，默认开启）───────────────────────────────────
# 设置为 false 以信任自签名证书（私有 GitLab 实例、企业 MITM 代理等）
# TLS_REJECT_UNAUTHORIZED=false

# ── Mock / 调试模式（可选，仅开发用）────────────────────────────
# 设为 1 时应用使用 lib/mock 中的夹具数据，跳过 PostgreSQL 与鉴权，
# 便于在无后端环境下调试前端。NEXT_PUBLIC_ 版本用于前端显示 "MOCK MODE" 角标。
# 严禁在生产环境启用！
# MOCK_DATA=1
# NEXT_PUBLIC_MOCK_DATA=1
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.3.0",
    "tailwindcss": "^4.3.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.9"
  },

{
  "name": "dashboard",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build --webpack",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",

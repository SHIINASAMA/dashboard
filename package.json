    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.6",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "jose": "^6.2.3",
    "lodash": "^4.17.21",
    "lucide-react": "^1.17.0",
    "next": "^16.2.10",
    "pg": "8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "recharts": "^3.9.2",
